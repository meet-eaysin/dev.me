# Shared runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3001

# Core services
MONGODB_URI=mongodb://localhost:27017/mindstack
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Auth and crypto
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-a-second-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# API app
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
WEB_APP_URL=http://localhost:5273
CORS_ORIGIN=http://localhost:5273

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# Web app
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_DEV_USER_ID=65f1a2b3c4d5e6f7a8b9c0d3
NEXT_PUBLIC_WEBAPP_URL=http://localhost:5273
NEXT_PUBLIC_CALCOM_VERSION=dev
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=local
