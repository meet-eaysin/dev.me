# Runtime
NODE_ENV=test
HOST=0.0.0.0
PORT=3001

# Core services
MONGODB_URI=mongodb://127.0.0.1:27017/mindstack_test
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Auth and crypto
JWT_SECRET=local-test-jwt-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=local-test-refresh-secret
REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_KEY=12345678901234567890123456789012

# App settings
FILE_UPLOAD_DIR=./uploads/test
MAX_FILE_SIZE_MB=50
WEB_APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://localhost:5273

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback
