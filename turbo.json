{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "globalEnv": [
        "MONGODB_URI",
        "JWT_SECRET",
        "QDRANT_API_KEY",
        "JEST_WORKER_ID",
        "ENABLE_EXPERIMENTAL_COREPACK",
        "NODE_ENV",
        "NODE_TLS_REJECT_UNAUTHORIZED"
      ]
    },
    "lint": {},
    "test": {},
    "test:e2e": {}
  }
}
